# Supabase (전자서명 서비스 전용 프로젝트)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 서명 링크/콜백에 쓰일 이 서비스의 공개 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 외부 앱(FM OS·MomoCare)이 REST API 호출 시 쓸 키. 콤마로 여러 개.
# 형식: label:key  (예: fm_os:sk_live_xxx,momocare:sk_live_yyy)
# 비워두면 API는 DB의 api_keys 테이블을 사용.
SIGN_API_KEYS=

# (선택) 이메일 발송 — 미설정 시 서명 링크를 로그/화면에 노출하는 데모 모드
RESEND_API_KEY=
SIGN_FROM_EMAIL=noreply@example.com
